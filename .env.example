# hevy2garmin environment variables

# Required: Hevy API key (requires Hevy Pro subscription)
# Get yours at https://hevy.com/settings > Integrations & API > Generate API Key
HEVY_API_KEY=

# Optional: GitHub PAT with repo+workflow scopes (enables auto-sync via GitHub Actions)
# Create one at: https://github.com/settings/tokens/new?scopes=repo,workflow&description=hevy2garmin
GITHUB_PAT=

# Required: Garmin Connect credentials (used for initial auth on all platforms)
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Optional: dashboard password. When set, all routes require login.
H2G_PASSWORD=

# Optional: argon2 hash of the dashboard password — use INSTEAD of H2G_PASSWORD so the
# plaintext never lives in the environment. Generate: hevy2garmin hash-password
H2G_PASSWORD_HASH=

# Optional but recommended (especially with H2G_PASSWORD_HASH): dedicated session-signing
# secret. Decouples cookie signing from the password (rotating it no longer logs everyone
# out). Without it, the signing key derives from the password (or its hash).
H2G_SECRET=

# Optional: how long a login lasts, in days, before re-auth is required (default: 30).
H2G_SESSION_TTL_DAYS=

# Optional: set to 'true' to run in demo mode (disables sync, shows banner)
DEMO_MODE=

# Optional: CSRF protection secret for POST endpoints
HEVY2GARMIN_SECRET=

# ── Vercel-specific (auto-set by Vercel) ──────────────────────────────────
# DATABASE_URL=              # Auto-set by Vercel Postgres integration
# VERCEL=1                   # Auto-set when running on Vercel
# VERCEL_GIT_REPO_OWNER=     # Auto-set: GitHub username
# VERCEL_GIT_REPO_SLUG=      # Auto-set: repo name
